# 朗朗上口 — 环境变量配置模板
# 复制本文件为 .env 后按需修改
# Docker 和本地启动都会自动读取 .env

# ========== AI 释义来源配置 ==========
# 可选值：ollama（默认） | openai
EXPLAINER_PROVIDER=ollama

# ========== 日志配置 ==========
# 可选值：DEBUG | INFO | WARNING | ERROR
# DEBUG 会输出详细的模型请求/响应日志，方便排查连接问题
LOG_LEVEL=INFO

# ========== Ollama 配置 ==========
OLLAMA_BASE_URL=http://localhost:11434
# Docker 环境下使用 host.docker.internal（由 docker-compose extra_hosts 解析）
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_TIMEOUT_SECONDS=180.0
OLLAMA_BATCH_SIZE=40

# ========== OpenAI 兼容接口配置 ==========
# 当 EXPLAINER_PROVIDER=openai 时生效
# 支持：OpenAI、Claude、Azure OpenAI、本地 vLLM 等
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_SECONDS=180.0
# OPENAI_BATCH_SIZE=40
